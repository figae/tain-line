{
  "name": "Tain Line — Celtic Mythology",

  // Build from our own Dockerfile instead of pulling the plain image.
  // Context is the project root so the Dockerfile can COPY package*.json.
  // Heavy work (apt-get, npm ci, playwright browser) is baked into the image
  // layer — it only re-runs when the Dockerfile or package*.json changes.
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // Expose the cache paths that were set inside the Dockerfile
  "containerEnv": {
    "NPM_CONFIG_CACHE": "/opt/npm-cache",
    "PLAYWRIGHT_BROWSERS_PATH": "/opt/playwright-browsers"
  },

  // Forward the Next.js dev server port
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js Dev Server",
      "onAutoForward": "openPreview"
    }
  },

  // postCreateCommand is now fast:
  //   • npm ci reads from the pre-warmed /opt/npm-cache  → no network
  //   • db:reset just writes a SQLite file               → instant
  "postCreateCommand": "npm ci --prefer-offline && npm run db:reset -- core",

  // On every container start: keep deps in sync (handles platform rebuilds)
  "postStartCommand": "npm install --prefer-offline 2>/dev/null || true",

  "customizations": {
    "vscode": {
      "extensions": [
        // Linting & formatting
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // TypeScript & React
        "yoavbls.pretty-ts-errors",
        "dsznajder.es7-react-js-snippets",
        "formulahendry.auto-rename-tag",

        // Tailwind
        "bradlc.vscode-tailwindcss",

        // SQLite
        "qwtel.sqlite-viewer",

        // Git
        "eamodio.gitlens",

        // DX
        "usernamehw.errorlens",
        "christian-kohler.path-intellisense",
        "mikestead.dotenv",

        // UI
        "PKief.material-icon-theme",

        // Testing
        "vitest.explorer",
        "ms-playwright.playwright"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib",
        "tailwindCSS.experimental.configFile": null
      }
    }
  },

  // Persist the SQLite database across rebuilds
  "mounts": [
    "source=${localWorkspaceFolderBasename}-db,target=${containerWorkspaceFolder}/data,type=volume"
  ],

  "remoteUser": "node"
}
