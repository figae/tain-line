{
  "name": "Tain Line — Celtic Mythology",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",

  // Forward the Next.js dev server port
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js Dev Server",
      "onAutoForward": "openPreview"
    }
  },

  // On first container creation: install deps on the correct platform,
  // then create/update the SQLite schema and seed initial data.
  // NOTE: Playwright browser binaries are NOT installed here to keep
  // Codespace startup fast. Run `npm run test:e2e:install` once manually
  // when you need E2E tests.
  "postCreateCommand": "npm install && npm run db:reset -- core",

  // On every container start: keep deps in sync (handles platform rebuilds)
  "postStartCommand": "npm install --prefer-offline 2>/dev/null || true",

  "customizations": {
    "vscode": {
      "extensions": [
        // Linting & formatting
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // TypeScript & React
        "yoavbls.pretty-ts-errors",
        "dsznajder.es7-react-js-snippets",
        "formulahendry.auto-rename-tag",

        // Tailwind
        "bradlc.vscode-tailwindcss",

        // SQLite
        "qwtel.sqlite-viewer",

        // Git
        "eamodio.gitlens",

        // DX
        "usernamehw.errorlens",
        "christian-kohler.path-intellisense",
        "mikestead.dotenv",

        // UI
        "PKief.material-icon-theme",

        // Testing
        "vitest.explorer",
        "ms-playwright.playwright"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib",
        "tailwindCSS.experimental.configFile": null
      }
    }
  },

  // Persist the SQLite database across rebuilds
  // (node_modules lives in /workspaces which Codespaces already persists)
  "mounts": [
    "source=${localWorkspaceFolderBasename}-db,target=${containerWorkspaceFolder}/data,type=volume"
  ],

  "remoteUser": "node"
}
